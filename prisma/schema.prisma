generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  name             String?
  password         String?
  role             Role              @default(USER)
  image            String?
  phone            String?
  country          String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  accounts         Account[]
  astrologyReports AstrologyReport[]
  bookings         Booking[]
  sessions         Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model RetreatProgram {
  id              String        @id @default(cuid())
  title           String
  slug            String        @unique
  description     String
  duration        Int
  price           Float
  earlyBirdPrice  Float?
  maxParticipants Int
  includes        String[]
  highlights      String[]
  imageUrl        String?
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  bookings        Booking[]
  dates           RetreatDate[]
}

model RetreatDate {
  id          String         @id @default(cuid())
  programId   String
  startDate   DateTime
  endDate     DateTime
  seatsTotal  Int
  seatsBooked Int            @default(0)
  isActive    Boolean        @default(true)
  bookings    Booking[]
  program     RetreatProgram @relation(fields: [programId], references: [id])
}

model Booking {
  id              String         @id @default(cuid())
  userId          String
  programId       String
  dateId          String
  roomType        RoomType       @default(SHARED)
  status          BookingStatus  @default(PENDING)
  totalAmount     Float
  paidAmount      Float          @default(0)
  stripePaymentId String?
  notes           String?
  passportUrl     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  addons          Addon[]
  date            RetreatDate    @relation(fields: [dateId], references: [id])
  program         RetreatProgram @relation(fields: [programId], references: [id])
  user            User           @relation(fields: [userId], references: [id])
}

model Addon {
  id        String    @id @default(cuid())
  bookingId String
  type      AddonType
  price     Float
  status    String    @default("PENDING")
  booking   Booking   @relation(fields: [bookingId], references: [id])
}

model AstrologyReport {
  id          String    @id @default(cuid())
  userId      String
  type        AddonType
  birthDate   DateTime?
  birthTime   String?
  birthPlace  String?
  reportUrl   String?
  notes       String?
  assignedTo  String?
  status      String    @default("PENDING")
  zoomLink    String?
  scheduledAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id])
}

model Testimonial {
  id          String   @id @default(cuid())
  name        String
  country     String?
  retreat     String?
  content     String
  rating      Int      @default(5)
  imageUrl    String?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model BlogPost {
  id              String    @id @default(cuid())
  title           String
  slug            String    @unique
  content         String
  excerpt         String?
  imageUrl        String?
  category        String?
  tags            String[]
  isPublished     Boolean   @default(false)
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  canonicalUrl    String?
  metaDescription String?
  metaTitle       String?
  ogImage         String?
}

model GalleryImage {
  id          String   @id @default(cuid())
  src         String?
  imageUrl    String?
  alt         String?
  location    String?
  isPublished Boolean  @default(true)
  emoji       String   @default("🖼️")
  title       String
  category    String   @default("General")
  caption     String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  service   String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([read])
}

model Product {
  id            String          @id @default(cuid())
  slug          String          @unique
  name          String
  category      String
  description   String
  features      String[]
  price         Float
  originalPrice Float?
  rating        Float           @default(4.8)
  reviews       Int             @default(0)
  badge         String?
  imageUrl      String?
  icon          String          @default("🕉️")
  isActive      Boolean         @default(true)
  sortOrder     Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  items         ShopOrderItem[]
}

model ShopOrder {
  id            String            @id @default(cuid())
  orderNumber   String            @unique
  customerName  String
  email         String
  phone         String?
  address       String
  city          String
  country       String
  postalCode    String?
  notes         String?
  paymentMethod ShopPaymentMethod
  status        ShopOrderStatus   @default(PENDING)
  currency      String            @default("USD")
  subtotal      Float
  shipping      Float
  total         Float
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  items         ShopOrderItem[]

  @@index([createdAt])
  @@index([status])
  @@index([email])
}

model ShopOrderItem {
  id        String    @id @default(cuid())
  orderId   String
  productId String?
  name      String
  qty       Int
  price     Float
  order     ShopOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product?  @relation(fields: [productId], references: [id])
}

enum Role {
  USER
  ADMIN
}

enum RoomType {
  SHARED
  PRIVATE
  DELUXE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum AddonType {
  VEDIC_BIRTH_CHART
  KARMA_READING
  COMPATIBILITY_READING
  CAREER_GUIDANCE
  MEDITATION_INTEGRATION
}

enum ShopPaymentMethod {
  COD
  TRANSFER
  WHATSAPP
}

enum ShopOrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}
